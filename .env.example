# 赔率 API
# 兼容 /Users/tom/.openclaw/workspace/football 使用的 API-SPORTS 足球 API
ODDS_API_KEY=
ODDS_API_BASE=https://v3.football.api-sports.io
ODDS_BOOKMAKER_ID=
FOOTBALL_CONFIG_PATH=/Users/tom/.openclaw/workspace/football/config.json
SYNC_ODDS_LIMIT=16
MATCH_DATE=
MATCH_LIMIT=8
# 赔率备源:The Odds API。主源 API-SPORTS 限流/返回空盘口时自动尝试。
BACKUP_ODDS_API_KEY=
BACKUP_ODDS_API_BASE=https://api.the-odds-api.com/v4
BACKUP_ODDS_SPORT_KEY=soccer_fifa_world_cup
BACKUP_ODDS_REGIONS=uk,eu,us,au
BACKUP_ODDS_BOOKMAKERS=
# 中国竞彩网官方胜平负(HAD)赔率会作为免 key 权威站点备源自动尝试。
# 本地手工备用赔率文件;缺省读取 public/data/odds-fallback.json(不存在则跳过)。条目必须带 source/sourceHref/sourceLabel。
ODDS_FALLBACK_PATH=
API_TIMEOUT_MS=60000
CLAUDE_CLI_TIMEOUT_MS=180000
CLAUDE_CLI_EXTRA_ARGS=

# 各大模型 API key(按需填写,缺失则该模型自动跳过)
ZENMUX_API_KEY=
ZENMUX_API_BASE=https://zenmux.ai/api/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=https://api.anthropic.com/v1
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://zenmux.ai/api/anthropic
# Claude Fable 5 专用 DK key,极贵,只用于启用 Fable 5。
# 实际调用走本机 Claude Code CLI,并用 --model claude-fable-5 覆盖默认模型。
DK_ANTHROPIC_API_KEY=
DK_ANTHROPIC_API_BASE=https://dk.claudecode.love/v1
# Claude Opus 4.8 如需继续走 DK,请使用独立 key,避免和 Fable 5 混用。
DK_OPUS_ANTHROPIC_API_KEY=
DK_OPUS_ANTHROPIC_API_BASE=https://dk.claudecode.love/v1
GOOGLE_API_KEY=
GEMINI_API_KEY=
GOOGLE_GEMINI_BASE_URL=https://zenmux.ai/api/vertex-ai
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
XAI_API_KEY=
ZHIPU_API_KEY=
MOONSHOT_API_KEY=
MINIMAX_API_KEY=
MIMO_API_KEY=
MIMO_API_BASE=
MIMO_ANTHROPIC_API_KEY=
MIMO_ANTHROPIC_API_BASE=https://token-plan-cn.xiaomimimo.com/anthropic/v1
MUSE_API_KEY=
MUSE_API_BASE=

OPENAI_MODEL=openai/gpt-5.5
GPT_5_5_MODEL=openai/gpt-5.5
CLAUDE_FABLE_MODEL=claude-fable-5
DK_CLAUDE_FABLE_MODEL=claude-fable-5
CLAUDE_OPUS_MODEL=claude-opus-4-8
DK_CLAUDE_OPUS_MODEL=claude-opus-4-8
DK_ANTHROPIC_MODEL=claude-opus-4-8
CLAUDE_SONNET_MODEL=anthropic/claude-sonnet-4.6
GOOGLE_MODEL=gemini-3.1-flash-lite-preview
GEMINI_MODEL=gemini-3.1-flash-lite-preview
QWEN_MODEL=qwen/qwen3.7-max
DASHSCOPE_MODEL=qwen/qwen3.7-max
MINIMAX_MODEL=minimax/minimax-m3
KIMI_MODEL=moonshotai/kimi-k2.6
MOONSHOT_MODEL=moonshotai/kimi-k2.6
MIMO_MODEL=mimo-v2.5-pro
MIMO_ANTHROPIC_MODEL=mimo-v2.5-pro
GROK_MODEL=x-ai/grok-4.3
XAI_MODEL=x-ai/grok-4.3
MUSE_MODEL=muse-spark
DEEPSEEK_MODEL=deepseek/deepseek-v4-pro
GLM_MODEL=z-ai/glm-5.1
ZHIPU_MODEL=z-ai/glm-5.1
DOUBAO_MODEL=bytedance/doubao-seed-2.0-pro

SETTLEMENT_GRACE_MINUTES=150
SETTLE_WATCH_INTERVAL_SECONDS=300
SETTLE_WATCH_DURATION_SECONDS=21600
