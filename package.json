{
  "name": "worldcup-ai-arena",
  "version": "0.1.0",
  "private": true,
  "description": "Static World Cup AI prediction arena with sealed model picks and result/score accuracy leaderboards.",
  "type": "commonjs",
  "scripts": {
    "predict": "node pipeline/predict.js",
    "discuss": "node pipeline/discuss.js",
    "legion": "node pipeline/legion.js",
    "sync:jingcai": "node pipeline/sync-jingcai-single.js",
    "sync:espn-results": "node pipeline/sync-espn-results.js",
    "sync:odds": "node pipeline/sync-odds.js",
    "sync:real": "node pipeline/sync-real-data.js",
    "champion": "node pipeline/champion.js",
    "score": "node pipeline/score.js",
    "insights": "node pipeline/update-match-insights.js",
    "validate:predictions": "node pipeline/validate-predictions.js",
    "validate:results": "node pipeline/validate-results.js",
    "validate:insights": "node pipeline/validate-match-insights.js",
    "audit:predictions": "node pipeline/audit-prediction-provenance.js",
    "recap": "node pipeline/recap.js",
    "settle": "node pipeline/settle.js",
    "settle:strict": "node pipeline/settle.js --fail-on-pending --fail-on-conflict",
    "settle:watch": "node pipeline/settle-watch.js",
    "roundtable:auto": "node pipeline/auto-roundtable.js",
    "champion:gauntlet": "node pipeline/champion-gauntlet.js",
    "champion:gauntlet:settle": "node pipeline/champion-gauntlet.js --settle",
    "publish:settle": "node pipeline/auto-publish.js settle",
    "publish:roundtable": "node pipeline/auto-publish.js roundtable",
    "analytics:deploy": "npx wrangler deploy",
    "analytics:migrate": "npx wrangler d1 execute worldcup_ai_arena_analytics --remote --file worker/schema.sql",
    "analytics:dev": "npx wrangler dev",
    "score:sample": "node pipeline/score.js --input public/data/sample-matches.json --output public/data/leaderboard.json",
    "export:mobile": "node pipeline/export-standalone.js worldcup-ai-arena-mobile.html",
    "serve": "python3 -m http.server -d public 8080"
  },
  "engines": {
    "node": ">=18"
  }
}
